async function runPortfolioWorkflow({ flags, repoRoot }) {
  const intake = await collectPortfolioInput(flags);
  const slug = intake.slug?.trim() ? slugify(intake.slug) : slugify(intake.projectGoals);
  if (!slug) {
    throw new Error("Could not derive a valid project slug. Use clearer goals or pass --slug.");
  }
  const projectPath = path.join(repoRoot, "projects", slug);
  const privacyCheck = privacyBlock(projectPath);
  if (privacyCheck.blocked) {
    throw new Error(privacyCheck.reason);
  }
  const providerCheck = providerKeyGate([]);
  if (!providerCheck.ok) {
    throw new Error(`Provider key gate failed: ${providerCheck.missing.join(", ")}`);
  }

  await projectPreflight({
    repoRoot,
    projectSlug: slug,
    targetPath: projectPath,
    force: flags.force === "true",
  });

  const result = await generateProject({
    repoRoot,
    outputPath: path.join(repoRoot, "projects", slug),
    intake,
    slug,
    preferFreeDeploy: intake.preferFreeDeploy,
    force: flags.force === "true",
  });

  const handoff = subagentInit({
    repoRoot,
    projectSlug: result.slug,
  });
  const validation = await validateGeneratedProject(result.projectRoot);

  console.log(`Created project: ${result.projectRoot}`);
  console.log(`Framework: ${result.decisions.framework.name}`);
  console.log(`Layer: ${result.decisions.layer.name}`);
  console.log(`Tool: ${result.decisions.tool.name}`);
  console.log(`Validation: checked ${validation.checked} required paths`);
  console.log(`Codex handoff: ${JSON.stringify(handoff, null, 2)}`);
}

module.exports = {
  runPortfolioWorkflow,
};
</file>

<file path="scripts/lib/project-generator.cjs">
const path = require("node:path");

const { buildDecisionBundle } = require("./selector.cjs");
const { pathExists, safeRemoveDir, slugify, writeMany } = require("./fs-utils.cjs");
const {
  renderIntakeDoc,
  renderOverviewDoc,
  renderProjectGitignore,
  renderProjectReadme,
  renderRequirementsDoc,
} = require("./project-templates.cjs");
const {
  renderPhaseDataWork,
  renderPhaseIntake,
  renderPhasePublishing,
  renderPhaseVisualization,
  renderPlan,
} = require("./project-plan-templates.cjs");

async function generateProject(options) {
  const slug = options.slug && options.slug.trim() ? slugify(options.slug) : slugify(options.intake.projectGoals);
  if (!slug) {
    throw new Error("Project slug resolved to an empty value. Provide an explicit slug or clearer goals.");
  }

  const projectRoot = options.outputPath ?? path.join(options.repoRoot, "projects", slug);
  const projectsRoot = path.join(options.repoRoot, "projects");
  const relative = path.relative(projectsRoot, projectRoot);
  if (!relative || relative.startsWith("..") || path.isAbsolute(relative)) {
    throw new Error(`Project output path must stay inside projects/: ${projectRoot}`);
  }
  const exists = await pathExists(projectRoot);

  if (exists && !options.force) {
    throw new Error(`Project path already exists: ${projectRoot}`);
  }
  if (exists && options.force) {
    await safeRemoveDir(projectRoot, projectsRoot);
  }

  const decisions = buildDecisionBundle({
    projectGoals: options.intake.projectGoals,
    preferFreeDeploy: options.preferFreeDeploy,
  });

  const files = {
    [path.join(projectRoot, "README.md")]: renderProjectReadme({ slug, intake: options.intake, decisions }),
    [path.join(projectRoot, ".gitignore")]: renderProjectGitignore(),
    [path.join(projectRoot, "docs", "project-intake.md")]: renderIntakeDoc(options.intake, slug),
    [path.join(projectRoot, "docs", "project-overview.md")]: renderOverviewDoc(decisions),
    [path.join(projectRoot, "docs", "requirements-rationale-tools.md")]: renderRequirementsDoc({
      intake: options.intake,
      decisions,
      preferFreeDeploy: options.preferFreeDeploy,
    }),
    [path.join(projectRoot, "plans", "plan.md")]: renderPlan(decisions),
    [path.join(projectRoot, "plans", "phase-01-intake.md")]: renderPhaseIntake(options.intake),
    [path.join(projectRoot, "plans", "phase-02-data-work.md")]: renderPhaseDataWork(decisions),
    [path.join(projectRoot, "plans", "phase-03-visualization.md")]: renderPhaseVisualization(decisions),
    [path.join(projectRoot, "plans", "phase-04-publishing.md")]: renderPhasePublishing(decisions),
    [path.join(projectRoot, "plans", "reports", ".gitkeep")]: "",
    [path.join(projectRoot, "assets", "data", ".gitkeep")]: "",
    [path.join(projectRoot, "assets", "visuals", ".gitkeep")]: "",
    [path.join(projectRoot, "assets", "sql", "01-analysis.sql")]: buildSqlStarter(options.intake),
  };

  if (decisions.layer.requiresPython) {
    files[path.join(projectRoot, "assets", "python", "01-analysis.py")] = buildPythonStarter(options.intake);
  } else {
    files[path.join(projectRoot, "assets", "python", ".gitkeep")] = "";
  }

  await writeMany(files);
  return { decisions, projectRoot, slug };
}

function buildSqlStarter(intake) {
  const context = flattenLine(intake.projectContext);
  const dataset = flattenLine(intake.projectDataset);
  return `-- Starter SQL for the generated portfolio project
-- Context: ${context}
-- Dataset: ${dataset}

select *
from your_source_table
limit 100;
`;
}

function buildPythonStarter(intake) {
  const context = toPythonStringLiteral(intake.projectContext);
  const dataset = toPythonStringLiteral(intake.projectDataset);
  return `"""Starter Python for the generated portfolio project."""

def describe_project():
    return {
        "context": ${context},
        "dataset": ${dataset},
        "next_step": "Implement cleaning, feature work, or advanced analysis here.",
    }


if __name__ == "__main__":
    print(describe_project())
`;
}

function flattenLine(value) {
  return String(value).replace(/\s+/g, " ").trim();
}

function toPythonStringLiteral(value) {
  return JSON.stringify(String(value));
}

module.exports = {
  generateProject,
};
</file>

