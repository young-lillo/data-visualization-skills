const path = require("node:path");

const { collectPortfolioInput } = require("./cli.cjs");
const { slugify } = require("./fs-utils.cjs");
const { generateProject } = require("./project-generator.cjs");
const { validateGeneratedProject } = require("./project-validator.cjs");
const { privacyBlock } = require("../hooks/privacy-block.cjs");
