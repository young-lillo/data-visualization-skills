const path = require("node:path");

function privacyBlock(filePath) {
  const blockedNames = [".env", ".env.local", ".env.production", "secrets.json", "id_rsa"];
  const baseName = path.basename(filePath).toLowerCase();
  const blocked = blockedNames.includes(baseName) || baseName.includes("token");

  return {
    blocked,
    reason: blocked ? `Sensitive file access blocked: ${filePath}` : "ok",
  };
}

if (require.main === module) {
  console.log(JSON.stringify(privacyBlock(process.argv[2] || ""), null, 2));
}

module.exports = {
